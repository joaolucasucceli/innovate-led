# ===========================================
# Central Innovate — Variáveis de Ambiente
# ===========================================
# Copie este arquivo para .env.local e preencha os valores

# Banco de Dados (Supabase)
DATABASE_URL="postgresql://postgres:[SENHA]@db.[PROJECT_REF].supabase.co:5432/postgres"

# NextAuth
NEXTAUTH_SECRET="" # gerar com: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3100"

# Redis (Upstash)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# OpenAI
OPENAI_API_KEY=""

# Supabase (client-side + server)
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# CRON (Vercel Cron Jobs)
CRON_SECRET=""

# API Interna (header x-api-secret)
API_SECRET=""

# Kommo CRM (integração direta via API)
KOMMO_API_TOKEN=""

# Webhook WhatsApp (validação de payload)
WEBHOOK_SECRET=""
