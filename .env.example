UPSTASH_REDIS_REST_TOKEN=""

# OpenAI
OPENAI_API_KEY=""

# WhatsApp (Uazapi)
UAZAPI_URL=""
UAZAPI_TOKEN=""

# Google Calendar
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REFRESH_TOKEN=""
GOOGLE_CALENDAR_ID=""

# Supabase (client-side + server)
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
