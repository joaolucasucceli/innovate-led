// Central Dr. Lucas — Schema Prisma
// Todos os nomes de campos em português (camelCase)

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// Enums
// ==========================================

enum Perfil {
  gestor
  atendente
}

enum TipoUsuario {
  humano
  ia
}

enum StatusFunil {
  acolhimento
  qualificacao
  agendamento
  consulta_agendada
  consulta_realizada
  sinal_pago
  procedimento_agendado
  concluido
  perdido
}

enum EtapaConversa {
  acolhimento
  qualificacao
  agendamento
  consulta_agendada
  consulta_realizada
  sinal_pago
  procedimento_agendado
  concluido
  perdido
}

enum StatusAgendamento {
  agendado
  confirmado
  cancelado
  realizado
  remarcado
}

enum TipoMensagem {
  texto
  audio
  imagem
  documento
  video
}

enum ModoConversa {
  ia
  humano
  hibrido
}

enum StatusSprint {
  planejada
  em_andamento
  concluida
}

// ==========================================
// Models
// ==========================================

model Usuario {
  id          String       @id @default(cuid())
  nome        String
  email       String       @unique
  senha       String
  perfil      Perfil
  tipo        TipoUsuario  @default(humano)
  ativo       Boolean      @default(true)
  criadoEm    DateTime     @default(now())
  atualizadoEm DateTime   @updatedAt
  deletadoEm  DateTime?

  leads       Lead[]       @relation("ResponsavelLead")
  conversas   Conversa[]   @relation("AtendenteConversa")
  auditLogs   AuditLog[]

  @@map("usuarios")
}

model Lead {
  id                    String       @id @default(cuid())
  nome                  String
  whatsapp              String       @unique
  email                 String?
  procedimentoInteresse String?
  statusFunil           StatusFunil  @default(acolhimento)
  origem                String?
  sobreOPaciente        String?      @db.Text
  responsavelId         String?
  arquivado             Boolean      @default(false)
  arquivadoEm           DateTime?
  consentimentoLgpd     Boolean      @default(false)
  consentimentoLgpdEm   DateTime?
  criadoEm              DateTime     @default(now())
  atualizadoEm          DateTime     @updatedAt
  motivoPerda           String?
  ultimaMovimentacaoEm  DateTime?
  deletadoEm            DateTime?
  cicloAtual            Int          @default(1)
  ciclosCompletos       Int          @default(0)
  ehRetorno             Boolean      @default(false)

  responsavel   Usuario?           @relation("ResponsavelLead", fields: [responsavelId], references: [id])
  conversas     Conversa[]
  agendamentos  Agendamento[]
  mensagens     MensagemWhatsapp[]
  fotos         FotoLead[]
  paciente      Paciente?

  @@index([responsavelId])
  @@index([statusFunil])
  @@index([criadoEm])
  @@map("leads")
}

model Conversa {
  id                String        @id @default(cuid())
  leadId            String
  etapa             EtapaConversa @default(acolhimento)
  modoConversa      ModoConversa  @default(ia)
  atendenteId       String?
  ultimaMensagemEm  DateTime?
  followUpEnviados  String[]      @default([])
  encerradaEm       DateTime?
  ciclo             Int           @default(1)
  criadoEm          DateTime      @default(now())
  atualizadoEm      DateTime      @updatedAt

  lead       Lead                @relation(fields: [leadId], references: [id])
  atendente  Usuario?            @relation("AtendenteConversa", fields: [atendenteId], references: [id])
  mensagens  MensagemWhatsapp[]

  @@index([leadId])
  @@index([etapa])
  @@index([atendenteId])
  @@map("conversas")
}

model MensagemWhatsapp {
  id                  String        @id @default(cuid())
  conversaId          String
  leadId              String
  messageIdWhatsapp   String        @unique
  tipo                TipoMensagem
  conteudo            String        @db.Text
  remetente           String
  mediaUrl            String?
  mediaType           String?
  lidaEm              DateTime?
  replyToId           String?
  criadoEm            DateTime      @default(now())

  conversa  Conversa          @relation(fields: [conversaId], references: [id])
  lead      Lead              @relation(fields: [leadId], references: [id])
  replyTo   MensagemWhatsapp? @relation("MensagemReply", fields: [replyToId], references: [id])
  replies   MensagemWhatsapp[] @relation("MensagemReply")

  @@index([leadId])
  @@index([conversaId])
  @@index([criadoEm])
  @@index([replyToId])
  @@map("mensagens_whatsapp")
}

model Agendamento {
  id                    String            @id @default(cuid())
  leadId                String
  procedimentoId        String?
  dataHora              DateTime
  status                StatusAgendamento @default(agendado)
  googleEventId         String?
  googleEventUrl        String?
  sincronizado          Boolean           @default(false)
  duracao               Int               @default(60)
  observacao            String?           @db.Text
  confirmacoesEnviadas  String[]          @default([])
  ciclo                 Int               @default(1)
  criadoEm              DateTime          @default(now())
  atualizadoEm          DateTime          @updatedAt

  lead         Lead          @relation(fields: [leadId], references: [id])
  procedimento Procedimento? @relation(fields: [procedimentoId], references: [id])

  @@index([leadId])
  @@index([criadoEm])
  @@index([dataHora])
  @@index([procedimentoId])
  @@map("agendamentos")
}

model Procedimento {
  id             String    @id @default(cuid())
  nome           String
  tipo           String
  descricao      String?   @db.Text
  valorBase      Decimal?
  duracaoMin     Int
  posOperatorio  String?   @db.Text
  ativo          Boolean   @default(true)
  criadoEm       DateTime  @default(now())
  atualizadoEm   DateTime  @updatedAt
  deletadoEm     DateTime?

  agendamentos         Agendamento[]
  evolucoes            Evolucao[]
  agendamentosPaciente AgendamentoPaciente[]

  @@map("procedimentos")
}

model FotoLead {
  id          String   @id @default(cuid())
  leadId      String
  url         String
  descricao   String?
  tipoAnalise String?
  ciclo       Int      @default(1)
  criadoEm    DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id])

  @@index([leadId])
  @@map("fotos_lead")
}

model TipoProcedimento {
  id        String   @id @default(cuid())
  nome      String   @unique
  ativo     Boolean  @default(true)
  criadoEm  DateTime @default(now())

  @@map("tipos_procedimento")
}

model ConfigGoogleCalendar {
  id             String   @id @default(cuid())
  clientId       String
  clientSecret   String
  refreshToken   String?
  calendarId     String?
  ativo          Boolean  @default(true)
  criadoEm       DateTime @default(now())
  atualizadoEm   DateTime @updatedAt

  @@map("config_google_calendar")
}

model ConfigWhatsapp {
  id              String    @id @default(cuid())
  nome            String?
  uazapiUrl       String
  adminToken      String
  instanceId      String?
  instanceToken   String?
  numeroWhatsapp  String?
  webhookUrl      String?
  ativo           Boolean   @default(false)
  criadoEm        DateTime  @default(now())
  atualizadoEm    DateTime  @updatedAt

  @@map("config_whatsapp")
}

model ConfigSite {
  id                  String   @id @default(cuid())
  whatsappNumero      String?
  whatsappMensagem    String?
  medicoNome          String?
  medicoEspecialidade String?
  medicoCrm           String?
  instagramUrl        String?
  contatoTelefone     String?
  contatoEndereco     String?
  contatoCidade       String?
  ativo               Boolean  @default(true)
  criadoEm            DateTime @default(now())
  atualizadoEm        DateTime @updatedAt

  @@map("config_site")
}

model Sprint {
  id            String        @id @default(cuid())
  nome          String
  descricao     String?       @db.Text
  status        StatusSprint  @default(planejada)
  dataInicio    DateTime?
  dataFim       DateTime?
  ordem         Int           @default(0)
  criadoEm      DateTime      @default(now())
  atualizadoEm  DateTime      @updatedAt
  deletadoEm    DateTime?

  itens         SprintItem[]

  @@map("sprints")
}

model SprintItem {
  id          String   @id @default(cuid())
  sprintId    String
  titulo      String
  concluido   Boolean  @default(false)
  ordem       Int      @default(0)
  criadoEm    DateTime @default(now())

  sprint      Sprint   @relation(fields: [sprintId], references: [id], onDelete: Cascade)

  @@index([sprintId])
  @@map("sprint_itens")
}

model AuditLog {
  id          String   @id @default(cuid())
  usuarioId   String?
  acao        String
  entidade    String
  entidadeId  String?
  dadosAntes  Json?
  dadosDepois Json?
  ip          String?
  criadoEm    DateTime @default(now())

  usuario     Usuario? @relation(fields: [usuarioId], references: [id])

  @@index([entidade, entidadeId])
  @@index([usuarioId])
  @@map("audit_logs")
}

// ==========================================
// Enums — Prontuário
// ==========================================

enum TipoEvolucao {
  consulta
  procedimento
  retorno
  prescricao
  intercorrencia
  observacao
}

enum TipoDocumentoProntuario {
  exame_laboratorial
  laudo
  termo_consentimento
  receita
  atestado
  outro
}

enum TipoSinalVital {
  pressao_arterial
  frequencia_cardiaca
  temperatura
  saturacao_o2
  glicemia
}

enum TipoAnestesia {
  local
  sedacao
  geral
  raquidiana
  peridural
  bloqueio_regional
}

// ==========================================
// Models — Pacientes & Prontuário
// ==========================================

model Paciente {
  id                    String    @id @default(cuid())
  nome                  String
  whatsapp              String?
  email                 String?
  cpf                   String?   @unique
  dataNascimento        DateTime?
  sexo                  String?
  endereco              String?
  cidade                String?
  estado                String?
  contatoEmergencia     String?
  contatoEmergenciaTel  String?
  observacoes           String?   @db.Text
  consentimentoLgpd     Boolean   @default(false)
  consentimentoLgpdEm   DateTime?
  leadOrigemId          String?   @unique
  ativo                 Boolean   @default(true)
  criadoEm              DateTime  @default(now())
  atualizadoEm          DateTime  @updatedAt
  deletadoEm            DateTime?

  leadOrigem    Lead?                  @relation(fields: [leadOrigemId], references: [id])
  prontuario    Prontuario?
  agendamentos  AgendamentoPaciente[]

  @@index([nome])
  @@index([whatsapp])
  @@index([cpf])
  @@map("pacientes")
}

model Prontuario {
  id            String   @id @default(cuid())
  pacienteId    String   @unique
  numero        Int
  criadoEm      DateTime @default(now())
  atualizadoEm  DateTime @updatedAt

  paciente      Paciente               @relation(fields: [pacienteId], references: [id], onDelete: Cascade)
  anamnese      Anamnese?
  evolucoes     Evolucao[]
  documentos    DocumentoProntuario[]
  fotos         FotoProntuario[]
  sinaisVitais  SinalVital[]

  @@map("prontuarios")
}

model Anamnese {
  id                    String    @id @default(cuid())
  prontuarioId          String    @unique
  queixaPrincipal       String?   @db.Text
  historicoMedico       String?   @db.Text
  cirurgiasAnteriores   String?   @db.Text
  alergias              String?   @db.Text
  medicamentosEmUso     String?   @db.Text
  doencasPreExistentes  String?   @db.Text
  tabagismo             Boolean?
  etilismo              Boolean?
  atividadeFisica       String?
  gestacoes             String?
  anticoncepcional      String?
  pesoKg                Decimal?
  alturaCm              Decimal?
  imc                   Decimal?
  pressaoArterial       String?
  observacoes           String?   @db.Text
  criadoEm              DateTime  @default(now())
  atualizadoEm          DateTime  @updatedAt

  prontuario  Prontuario @relation(fields: [prontuarioId], references: [id], onDelete: Cascade)

  @@map("anamneses")
}

model Evolucao {
  id              String        @id @default(cuid())
  prontuarioId    String
  tipo            TipoEvolucao
  dataRegistro    DateTime      @default(now())
  titulo          String
  conteudo        String        @db.Text
  prescricao      String?       @db.Text
  orientacoes     String?       @db.Text
  procedimentoId  String?
  criadoEm        DateTime      @default(now())
  atualizadoEm    DateTime      @updatedAt
  deletadoEm      DateTime?

  prontuario         Prontuario          @relation(fields: [prontuarioId], references: [id], onDelete: Cascade)
  procedimento       Procedimento?       @relation(fields: [procedimentoId], references: [id])
  registroCirurgico  RegistroCirurgico?

  @@index([prontuarioId])
  @@index([dataRegistro])
  @@index([procedimentoId])
  @@map("evolucoes")
}

model DocumentoProntuario {
  id              String                    @id @default(cuid())
  prontuarioId    String
  tipo            TipoDocumentoProntuario
  nome            String
  descricao       String?
  storagePath     String
  tamanhoBytes    Int?
  mimeType        String?
  criadoEm        DateTime                  @default(now())

  prontuario  Prontuario @relation(fields: [prontuarioId], references: [id], onDelete: Cascade)

  @@index([prontuarioId])
  @@map("documentos_prontuario")
}

model FotoProntuario {
  id              String    @id @default(cuid())
  prontuarioId    String
  url             String
  descricao       String?
  tipoFoto        String?
  dataRegistro    DateTime  @default(now())
  criadoEm        DateTime  @default(now())

  prontuario  Prontuario @relation(fields: [prontuarioId], references: [id], onDelete: Cascade)

  @@index([prontuarioId])
  @@index([dataRegistro])
  @@map("fotos_prontuario")
}

model AgendamentoPaciente {
  id              String             @id @default(cuid())
  pacienteId      String
  procedimentoId  String?
  dataHora        DateTime
  status          StatusAgendamento  @default(agendado)
  tipo            String?
  observacao      String?            @db.Text
  criadoEm        DateTime           @default(now())
  atualizadoEm    DateTime           @updatedAt

  paciente      Paciente      @relation(fields: [pacienteId], references: [id], onDelete: Cascade)
  procedimento  Procedimento? @relation(fields: [procedimentoId], references: [id])

  @@index([pacienteId])
  @@index([dataHora])
  @@index([procedimentoId])
  @@map("agendamentos_paciente")
}

// ==========================================
// Models — Sinais Vitais & Registro Cirúrgico
// ==========================================

model SinalVital {
  id            String          @id @default(cuid())
  prontuarioId  String
  tipo          TipoSinalVital
  valor         String
  unidade       String
  dataRegistro  DateTime        @default(now())
  observacao    String?
  criadoEm      DateTime        @default(now())

  prontuario  Prontuario @relation(fields: [prontuarioId], references: [id], onDelete: Cascade)

  @@index([prontuarioId])
  @@index([tipo])
  @@index([dataRegistro])
  @@map("sinais_vitais")
}

model RegistroCirurgico {
  id                      String         @id @default(cuid())
  evolucaoId              String         @unique
  tipoAnestesia           TipoAnestesia
  anestesista             String?
  tempoCircurgicoMinutos  Int
  sangramento             String?
  complicacoes            String?        @db.Text
  tecnicaUtilizada        String         @db.Text
  materiaisUtilizados     String?        @db.Text
  orientacoesPosOp        String?        @db.Text
  marcosRecuperacao       Json?
  criadoEm                DateTime       @default(now())
  atualizadoEm            DateTime       @updatedAt

  evolucao  Evolucao @relation(fields: [evolucaoId], references: [id], onDelete: Cascade)

  @@index([evolucaoId])
  @@map("registros_cirurgicos")
}

