// Central Innovate — Schema Prisma
// Todos os nomes de campos em português (camelCase)

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// Enums
// ==========================================

enum Perfil {
  gestor
  atendente
}

enum TipoUsuario {
  humano
  ia
}

enum StatusFunil {
  qualificacao
  encaminhado
  tarefa_criada
  em_negociacao
  venda_realizada
  perdido
}

enum EtapaConversa {
  qualificacao
  encaminhado
  tarefa_criada
  em_negociacao
  venda_realizada
  perdido
}

enum TipoMensagem {
  texto
  audio
  imagem
  documento
  video
}

enum ModoConversa {
  ia
  humano
  hibrido
}

enum StatusSprint {
  planejada
  em_andamento
  concluida
}

// ==========================================
// Models
// ==========================================

model Usuario {
  id          String       @id @default(cuid())
  nome        String
  email       String       @unique
  senha       String
  perfil      Perfil
  tipo        TipoUsuario  @default(humano)
  ativo       Boolean      @default(true)
  criadoEm    DateTime     @default(now())
  atualizadoEm DateTime   @updatedAt
  deletadoEm  DateTime?

  leads       Lead[]       @relation("ResponsavelLead")
  conversas   Conversa[]   @relation("AtendenteConversa")
  auditLogs   AuditLog[]

  @@map("usuarios")
}

model Lead {
  id                    String       @id @default(cuid())
  nome                  String
  whatsapp              String       @unique
  email                 String?
  statusFunil           StatusFunil  @default(qualificacao)
  origem                String?
  sobreOLead            String?      @db.Text
  responsavelId         String?
  arquivado             Boolean      @default(false)
  arquivadoEm           DateTime?
  consentimentoLgpd     Boolean      @default(false)
  consentimentoLgpdEm   DateTime?
  criadoEm              DateTime     @default(now())
  atualizadoEm          DateTime     @updatedAt
  motivoPerda           String?
  ultimaMovimentacaoEm  DateTime?
  deletadoEm            DateTime?
  cicloAtual            Int          @default(1)
  ciclosCompletos       Int          @default(0)
  ehRetorno             Boolean      @default(false)

  responsavel   Usuario?           @relation("ResponsavelLead", fields: [responsavelId], references: [id])
  conversas     Conversa[]
  mensagens     MensagemWhatsapp[]
  fotos         FotoLead[]

  @@index([responsavelId])
  @@index([statusFunil])
  @@index([criadoEm])
  @@map("leads")
}

model Conversa {
  id                String        @id @default(cuid())
  leadId            String
  etapa             EtapaConversa @default(qualificacao)
  modoConversa      ModoConversa  @default(ia)
  atendenteId       String?
  ultimaMensagemEm  DateTime?
  followUpEnviados  String[]      @default([])
  encerradaEm       DateTime?
  ciclo             Int           @default(1)
  criadoEm          DateTime      @default(now())
  atualizadoEm      DateTime      @updatedAt

  lead       Lead                @relation(fields: [leadId], references: [id])
  atendente  Usuario?            @relation("AtendenteConversa", fields: [atendenteId], references: [id])
  mensagens  MensagemWhatsapp[]

  @@index([leadId])
  @@index([etapa])
  @@index([atendenteId])
  @@map("conversas")
}

model MensagemWhatsapp {
  id                  String        @id @default(cuid())
  conversaId          String
  leadId              String
  messageIdWhatsapp   String        @unique
  tipo                TipoMensagem
  conteudo            String        @db.Text
  remetente           String
  mediaUrl            String?
  mediaType           String?
  lidaEm              DateTime?
  replyToId           String?
  criadoEm            DateTime      @default(now())

  conversa  Conversa          @relation(fields: [conversaId], references: [id])
  lead      Lead              @relation(fields: [leadId], references: [id])
  replyTo   MensagemWhatsapp? @relation("MensagemReply", fields: [replyToId], references: [id])
  replies   MensagemWhatsapp[] @relation("MensagemReply")

  @@index([leadId])
  @@index([conversaId])
  @@index([criadoEm])
  @@index([replyToId])
  @@map("mensagens_whatsapp")
}

model FotoLead {
  id          String   @id @default(cuid())
  leadId      String
  url         String
  descricao   String?
  tipoAnalise String?
  ciclo       Int      @default(1)
  criadoEm    DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id])

  @@index([leadId])
  @@map("fotos_lead")
}

model ConfigWhatsapp {
  id              String    @id @default(cuid())
  nome            String?
  uazapiUrl       String
  adminToken      String
  instanceId      String?
  instanceToken   String?
  numeroWhatsapp  String?
  webhookUrl      String?
  ativo           Boolean   @default(false)
  criadoEm        DateTime  @default(now())
  atualizadoEm    DateTime  @updatedAt

  @@map("config_whatsapp")
}

model ConfigSite {
  id                  String   @id @default(cuid())
  whatsappNumero      String?
  whatsappMensagem    String?
  empresaNome         String?
  empresaSegmento     String?
  instagramUrl        String?
  contatoTelefone     String?
  contatoEndereco     String?
  contatoCidade       String?
  ativo               Boolean  @default(true)
  criadoEm            DateTime @default(now())
  atualizadoEm        DateTime @updatedAt

  @@map("config_site")
}

model Sprint {
  id            String        @id @default(cuid())
  nome          String
  descricao     String?       @db.Text
  status        StatusSprint  @default(planejada)
  dataInicio    DateTime?
  dataFim       DateTime?
  ordem         Int           @default(0)
  criadoEm      DateTime      @default(now())
  atualizadoEm  DateTime      @updatedAt
  deletadoEm    DateTime?

  itens         SprintItem[]

  @@map("sprints")
}

model SprintItem {
  id          String   @id @default(cuid())
  sprintId    String
  titulo      String
  concluido   Boolean  @default(false)
  ordem       Int      @default(0)
  criadoEm    DateTime @default(now())

  sprint      Sprint   @relation(fields: [sprintId], references: [id], onDelete: Cascade)

  @@index([sprintId])
  @@map("sprint_itens")
}

model AuditLog {
  id          String   @id @default(cuid())
  usuarioId   String?
  acao        String
  entidade    String
  entidadeId  String?
  dadosAntes  Json?
  dadosDepois Json?
  ip          String?
  criadoEm    DateTime @default(now())

  usuario     Usuario? @relation(fields: [usuarioId], references: [id])

  @@index([entidade, entidadeId])
  @@index([usuarioId])
  @@map("audit_logs")
}
